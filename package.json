{
  "name": "electron-test",
  "version": "1.0.0",
  "description": "Simple Electron app",
  "main": "main.js",
  "author": {
    "name": "Nolan Notargiacomo",
    "email": "nolan@bearstudio.fr"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.test.electron-test",
    "productName": "ElectronTest",
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "win": {
      "target": ["portable"],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": ["dmg"],
      "identity": null
    }
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  }
}
